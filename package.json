{
  "name": "attest-agent",
  "version": "0.1.0",
  "description": "Trustworthy, self-verifying web agent core — proposes actions, the harness validates real page refs, every action leaves auditable evidence.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "repl": "tsx examples/repl.ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@happy-dom/global-registrator": "^14.0.0",
    "@types/node": "^20.11.0",
    "happy-dom": "^14.0.0",
    "playwright": "^1.44.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
